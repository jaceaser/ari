# Generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# Instructions to create an AI Gateway API key here: https://vercel.com/ai-gateway
# API key required for non-Vercel deployments
AI_GATEWAY_API_KEY=****

# ── Phase 2: Backend API integration ──

# Public URL of this app (used for OpenGraph/social previews)
NEXT_PUBLIC_APP_URL=https://ari-web.azurewebsites.net

# Backend API URL (Quart server). Leave empty to use internal /api/chat endpoint.
# Set to http://localhost:8000 for local development with backend API
NEXT_PUBLIC_API_URL=

# Server-side override for API base URL (not exposed to browser)
# API_BASE_URL=http://localhost:8000

# Legacy API key auth (for /v1/* endpoints only)
# BACKEND_API_BEARER_TOKEN=

# JWT secret — MUST match the API server's JWT_SECRET for session auth
# JWT_SECRET=
