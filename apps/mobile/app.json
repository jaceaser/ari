{
  "expo": {
    "name": "ARI",
    "slug": "ari-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ari",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.reilabs.ari",
      "associatedDomains": [
        "applinks:reilabs.ai"
      ],
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "ari"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "ai.reilabs.ari",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "ari"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "reilabs.ai",
              "pathPrefix": "/auth/verify"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": false,
          "cameraPermission": "ARI needs camera access to take photos for your messages."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#0a0a0a"
        }
      ],
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "ndk": "27.0.12077973",
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      "./plugins/withAndroidMediaPermissionsRemoved"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "8b1fee66-b7ac-4040-9a9f-30d2ab47a37f"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "jaceaser"
  }
}
