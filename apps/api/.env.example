# =============================================================================
# ARI Backend API - Environment Variables
# =============================================================================

# --- Required: Azure OpenAI ---
AZURE_OPENAI_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-5.2-chat
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# --- Optional: System Prompt ---
# ARI_SYSTEM_PROMPT=Your custom system prompt here
# AZURE_OPENAI_SYSTEM_MESSAGE=Fallback system message if ARI_SYSTEM_PROMPT is not set

# --- Optional: Frontend / CORS ---
FRONTEND_URL=http://localhost:3000
# ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com  # Comma-separated. Defaults to FRONTEND_URL.

# --- Optional: Authentication (API Key — legacy /v1/* endpoints) ---
# API_KEYS=key1,key2,key3  # Comma-separated API keys. If unset, auth is disabled (local dev mode).

# --- Optional: Authentication (JWT — Phase 2 /sessions/*, /lead-runs/*, /auth/* endpoints) ---
# JWT_SECRET=your-jwt-secret-key  # Required for JWT auth. If unset, JWT auth is disabled (local dev mode).
# JWT_ALGORITHM=HS256
# SESSION_SECRET=your-session-secret  # Secret for Quart session cookies (used by /auth/exchange).

# --- Optional: Rate Limiting ---
# Rate limiting is automatic: 60 requests/minute per API key (or per IP when auth is disabled).

# --- Optional: Request Validation ---
# MAX_MESSAGE_LENGTH=32000   # Max characters per message content
# MAX_MESSAGES_COUNT=100     # Max messages per request
# ALLOWED_DEPLOYMENTS=gpt-5.2-chat,gpt-4o  # Additional allowed model names (comma-separated)

# --- Optional: MCP Tool Orchestration ---
MCP_ENABLED=True
MCP_BASE_URL=http://localhost:8100
# MCP_TIMEOUT_SECONDS=10
# MCP_TOOL_MAX_ROUNDS=2
# MCP_TOOL_MAX_CALLS_PER_ROUND=4

# --- Optional: Azure Cosmos DB (Phase 2 persistence) ---
# AZURE_COSMOSDB_ACCOUNT=your-cosmos-account
# AZURE_COSMOSDB_ACCOUNT_KEY=your-cosmos-key
# AZURE_COSMOSDB_DATABASE=db_conversation_history
# AZURE_COSMOSDB_SESSIONS_CONTAINER=sessions

# --- Optional: Debug ---
DEBUG=True
